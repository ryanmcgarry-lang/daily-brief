# ── SMTP Configuration ────────────────────────────────────────────────────────
# Outlook / Hotmail
SMTP_HOST=smtp-mail.outlook.com
SMTP_PORT=587

# Gmail alternative:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# (Gmail requires an App Password if 2-Factor Authentication is enabled —
#  generate one at: https://myaccount.google.com/apppasswords)

# ── Credentials ───────────────────────────────────────────────────────────────
SMTP_USER=your_sending_address@hotmail.co.uk
SMTP_PASS=your_password_here

# ── Recipient ─────────────────────────────────────────────────────────────────
EMAIL_TO=ryan_mcgarry@hotmail.co.uk
EMAIL_FROM_NAME=APAC Daily Brief
